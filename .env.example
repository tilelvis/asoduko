# Copy this file to .env and fill in the values from the Alien Developer Portal.
# For a SIMPLE Sudoku game (no payments, no auth, no DB) most of these are optional.
# They are listed here only to make future upgrades to the full Alien boilerplate easy.

# Next.js
NEXT_PUBLIC_APP_NAME="Alien Sudoku"

# When you register this miniapp in the Alien Developer Portal (https://dev.alien.org),
# you will receive a provider address and a slug. Put the public URL of your Vercel
# deployment as the "URL" and "Allowed Origins" in the portal — these are configured
# there, not via env vars.
