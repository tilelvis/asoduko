# ============================================================================
# Alien Sudoku — Environment Variables
# ============================================================================
# Most of these are OPTIONAL for the simple Sudoku-only build. They only
# become required when you wire up real Alien token (ALN) purchases.
#
# See:
#   - https://docs.alien.org/quickstart/install-boilerplate
#   - https://docs.alien.org/quickstart/create-miniapp
# ============================================================================

# --- App metadata -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Alien Sudoku"

# --- ALN token purchases (OPTIONAL) -----------------------------------------
# Your Alien provider address from the Developer Portal (Mini Apps page).
# When this is set, the in-app ALN Store will display real-product prices
# and route payments to this address via the Alien payment bridge.
# When this is NOT set, the store falls back to test products that simulate
# successful payments without moving real tokens — useful for local dev.
#
# Get it from: https://dev.alien.org/ → Mini Apps → your miniapp → Provider Address
NEXT_PUBLIC_ALIEN_RECIPIENT_ADDRESS=

# --- Webhook signature verification (OPTIONAL, for production) --------------
# If you later add a backend webhook at /api/webhooks/payment to verify
# on-chain settlements, set this to the Ed25519 public key (hex, 64 chars)
# from the Developer Portal. The simple Sudoku build does not need this.
# WEBHOOK_PUBLIC_KEY=
