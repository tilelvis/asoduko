# ============================================================================
# Alien Sudoku — Environment Variables
# ============================================================================
# The wallet has TWO modes:
#
#   1. FALLBACK MODE (dev/local) — no env vars required. ALN balance is
#      tracked in localStorage. Withdrawals are DISABLED. Purchases fail
#      gracefully. Useful for UI development.
#
#   2. SECURE MODE (production) — set the vars below. Balance is
#      server-authoritative (NeonDB Postgres). Withdrawals are signed
#      server-side and broadcast on-chain. Deposits are verified via
#      Ed25519-signed webhooks.
#
# Switching from fallback → secure mode is automatic once ALIEN_AUDIENCE
# and DATABASE_URL are set on the server.
# ============================================================================

# --- App metadata -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Alien Sudoku"

# --- NeonDB Postgres (REQUIRED for secure mode) -----------------------------
# Your NeonDB connection string. Get it from your Neon dashboard:
#   https://console.neon.tech/
# Use the POOLED connection (the one ending in "-pooler") for production.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- JWT verification (REQUIRED for secure mode) ----------------------------
# Your Alien provider address from the Developer Portal.
# Used as the expected `aud` claim for incoming JWTs.
ALIEN_AUDIENCE=

# JWKS endpoint for verifying SSO access tokens. Defaults to Alien production.
ALIEN_JWKS_URL=https://sso.alien-api.com/oauth/jwks

# --- Deposit verification (REQUIRED for deposits to credit) -----------------
# Ed25519 public key (hex, 64 chars) from the Developer Portal → Webhooks page.
# Used to verify that payment webhooks actually came from Alien.
WEBHOOK_PUBLIC_KEY=

# --- Withdrawals (REQUIRED for withdrawals to work) -------------------------
# Ed25519 PRIVATE key (hex, 64 chars) that the server uses to sign outgoing
# ALIEN token transfers. NEVER expose this to the client.
# Generate a new keypair for your hot wallet and store the private key here.
# Keep the corresponding public key funded with ALIEN tokens to honor
# withdrawals.
ALIEN_WITHDRAW_PRIVATE_KEY=

# Public recipient address (your provider address) — where deposits land.
# Also exposed to the client so the Alien payment bridge knows where to send.
NEXT_PUBLIC_ALIEN_RECIPIENT_ADDRESS=

# --- Wallet configuration (optional, has sensible defaults) -----------------
# Daily earn cap per user (ALN). Server-enforced, not client-trusted.
WALLET_DAILY_EARN_CAP=500

# Minimum withdrawal in ALN (dust protection).
WALLET_MIN_WITHDRAWAL=50

# Exchange rate: how many game ALN credits equal 1 real ALIEN token.
# 10 means 10 ALN = 1 ALIEN. Both deposits and withdrawals use this.
# So 50 ALN withdrawal = 5 ALIEN tokens sent to the player's wallet.
ALN_PER_ALIEN=10
